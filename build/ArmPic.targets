<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <GargoylePython Condition="'$(GargoylePython)'==''">python</GargoylePython>
  </PropertyGroup>
  <ItemGroup>
    <CustomBuild Include="@(ArmPic)">
      <FileType>Document</FileType>
      <Message>Assembling %(Filename)%(Extension)</Message>
      <Command>if not exist "$(IntDir)" mkdir "$(IntDir)"
armasm64 -nologo %(ArmAsmOptions) -o "$(IntDir)%(Filename).obj" "%(FullPath)"
"$(GargoylePython)" "$(MSBuildThisFileDirectory)extract_pic.py" "$(IntDir)%(Filename).obj" "$(OutDir)%(OutputFileName)" --section %(SectionName)</Command>
      <AdditionalInputs>$(MSBuildThisFileDirectory)extract_pic.py;%(AdditionalInputs)</AdditionalInputs>
      <Outputs>$(OutDir)%(OutputFileName)</Outputs>
    </CustomBuild>
  </ItemGroup>
</Project>
